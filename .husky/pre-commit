echo "Running pre-commit checks (tests + build in parallel)..."

npm run test:run &
TEST_PID=$!

npm run build &
BUILD_PID=$!

wait $TEST_PID
TEST_EXIT=$?

wait $BUILD_PID
BUILD_EXIT=$?

[ $TEST_EXIT -ne 0 ] && echo "\nPre-commit: tests failed."
[ $BUILD_EXIT -ne 0 ] && echo "\nPre-commit: build failed."

[ $TEST_EXIT -ne 0 ] || [ $BUILD_EXIT -ne 0 ] && exit 1

echo "\nAll pre-commit checks passed."
